# Dnsmasq configuration generated by tube
# Local DNS server for .test domain development

# Listen on localhost
listen-address=127.0.0.1
port=53

# No upstream servers for local development
no-resolv
no-poll

# Log queries (optional, can be noisy)
# log-queries

# Cache size
cache-size=1000

# Respond to all queries for configured domains
address=/{{.Proxy.LocalDomain}}/127.0.0.1

# Project-specific domains
{{range $name, $port := .Projects}}
address=/{{$name}}{{$.Proxy.LocalDomain}}/127.0.0.1
address=/www.{{$name}}{{$.Proxy.LocalDomain}}/127.0.0.1
{{end}}

# Allow all local addresses
local-service
